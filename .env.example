# ========================================
# Personal Knowledge AI Agent — .env
# ========================================

# --- LLM API ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...  # Optional
LLM_PROVIDER=anthropic    # anthropic | openai
LLM_MODEL=claude-3-5-sonnet-20241022

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=pka-secret-token
CHROMA_COLLECTION=pka_knowledge

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=pka-redis-pass

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pka_db
POSTGRES_USER=pka_user
POSTGRES_PASSWORD=pka-pg-pass

# --- GitHub (Optional, for tool use) ---
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-github-username

# --- Backend ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Persona Config ---
PERSONA_MODE=ENFP          # ENFP | INTP
USER_NAME=사용자
